{
  "name": "nuxt-enterprise-starter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky install",
    "clean": "rm -rf .nuxt .output node_modules/.cache"
  },
  "dependencies": {
    "@nuxt/image": "^1.8.0",
    "@nuxtjs/i18n": "^9.0.0",
    "@pinia/nuxt": "^0.10.0",
    "@vueuse/core": "^12.0.0",
    "@vueuse/nuxt": "^12.0.0",
    "nuxt": "^3.15.0",
    "ofetch": "^1.4.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current"
      ],
      "cpu": [
        "current"
      ]
    },
    "overrides": {
      "sharp": "^0.34.5"
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@nuxt/eslint": "^0.7.0",
    "@nuxt/test-utils": "^3.15.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/forms": "^0.5.0",
    "@tailwindcss/typography": "^0.5.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "happy-dom": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "nuxt-svgo": "^4.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}

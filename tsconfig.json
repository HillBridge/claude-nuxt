{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    ".nuxt/nuxt.d.ts",
    "app/**/*.ts",
    "app/**/*.vue",
    "server/**/*.ts",
    "layers/**/*.ts",
    "layers/**/*.vue",
    "nuxt.config.ts",
    "app.config.ts"
  ],
  "exclude": ["node_modules", ".output", "dist"]
}

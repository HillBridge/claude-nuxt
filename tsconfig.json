{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@/*": ["./app/*"],
      "#types/*": ["./app/types/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.vue",
    "server/**/*.ts",
    "layers/**/*.ts",
    "layers/**/*.vue",
    "nuxt.config.ts",
    "app.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    ".output",
    "dist"
  ]
}
